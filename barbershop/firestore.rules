rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn()
        && userDocExists()
        && getUserRole() in ['admin', 'barber'];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Cliente pode cancelar ou reagendar o próprio agendamento (sem alterar serviço/preço).
    function isClientOwnAppointmentUpdate() {
      return resource.data.clientId == request.auth.uid
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.barberId == resource.data.barberId
        && request.resource.data.serviceId == resource.data.serviceId
        && request.resource.data.serviceName == resource.data.serviceName
        && request.resource.data.price == resource.data.price
        && request.resource.data.durationMinutes == resource.data.durationMinutes
        && request.resource.data.status in ['agendado', 'cancelado'];
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn()
        && isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == 'client';
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /barbers/{barberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /availability/{availId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /appointments/{appointmentId} {
      // Agendamentos ativos são legíveis por clientes autenticados (cálculo de horários).
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.clientId == request.auth.uid ||
        resource.data.status == 'agendado'
      );
      allow create: if isSignedIn() && (
        request.resource.data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isSignedIn() && (isAdmin() || isClientOwnAppointmentUpdate());
      allow delete: if isAdmin();
    }
  }
}
